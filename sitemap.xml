		<loc>{{ "/" | absolute_url }}</loc>
	</url>
	<url>
		<loc>{{ "/countdown-ideas/" | absolute_url }}</loc>
	</url>
	{% assign sitemap_pages = site.guide_pages | sort: "nav_order" %}
